{
  "name": "fusionui-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "FusionUI — a Vue 3 design library with the stability of Vuetify and the looks of Vuesax.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "dev": "pnpm --filter @rukkiecodes/docs dev",
    "dev:docs": "pnpm --filter @rukkiecodes/docs dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "size": "node tools/check-bundle-size.mjs",
    "a11y": "node tools/a11y-check.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "axe-core": "^4.12.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "playwright": "^1.60.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.4.3",
    "vue-eslint-parser": "^9.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,mjs,cjs,json,scss,sass,md}": "prettier --write"
  }
}
