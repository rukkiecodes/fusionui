{
  "displayName": "FAvatarGroup",
  "props": {
    "max": {
      "type": "Number | String",
      "default": "0",
      "required": false,
      "description": "Show at most N avatars; the rest collapse into a +N indicator on the last visible one."
    },
    "float": {
      "type": "Boolean",
      "required": false,
      "description": "Lay avatars out side by side with spacing instead of overlapping them."
    },
    "class": {
      "type": "String | Array | Object",
      "required": false,
      "description": ""
    },
    "style": {
      "type": "String | Array | Object",
      "default": "null",
      "required": false,
      "description": ""
    }
  },
  "events": {},
  "slots": {
    "default": {
      "description": "The FAvatar children to stack."
    }
  }
}
