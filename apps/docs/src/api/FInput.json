{
  "displayName": "FInput",
  "props": {
    "modelValue": {
      "type": "String | Number",
      "default": "",
      "required": false,
      "description": "The input value (use with `v-model`)."
    },
    "type": {
      "type": "String",
      "default": "text",
      "required": false,
      "description": "Native input type — text, password, email, number, etc. `password` adds a reveal toggle."
    },
    "placeholder": {
      "type": "String",
      "required": false,
      "description": "Native placeholder (when not using a floating label)."
    },
    "label": {
      "type": "String",
      "required": false,
      "description": "Field label. Combine with `label-placeholder` for the floating label."
    },
    "labelPlaceholder": {
      "type": "Boolean",
      "required": false,
      "description": "Animates the label as a placeholder that floats up on focus."
    },
    "color": {
      "type": "String",
      "required": false,
      "description": "Focus accent color — a theme color name or any CSS color."
    },
    "variant": {
      "type": "String",
      "default": "default",
      "required": false,
      "description": "Field style — default (filled), underlined, or shadow."
    },
    "state": {
      "type": "String",
      "required": false,
      "description": ""
    },
    "progress": {
      "type": "Number | String",
      "default": "0",
      "required": false,
      "description": ""
    },
    "square": {
      "type": "Boolean",
      "required": false,
      "description": ""
    },
    "transparent": {
      "type": "Boolean",
      "required": false,
      "description": ""
    },
    "prependIcon": {
      "type": "String | Object | Function",
      "required": false,
      "description": "Icon shown before the input."
    },
    "appendIcon": {
      "type": "String | Object | Function",
      "required": false,
      "description": "Icon shown after the input."
    },
    "clearable": {
      "type": "Boolean",
      "required": false,
      "description": "Shows a clear button when the field has a value."
    },
    "block": {
      "type": "Boolean",
      "required": false,
      "description": "Stretches the field to the full container width."
    },
    "loading": {
      "type": "Boolean",
      "required": false,
      "description": "Shows an inline loading spinner."
    },
    "hint": {
      "type": "String",
      "required": false,
      "description": "Helper text shown below the field."
    },
    "persistentHint": {
      "type": "Boolean",
      "required": false,
      "description": "Keeps the hint visible even when not focused."
    },
    "rules": {
      "type": "Array",
      "default": "[]",
      "required": false,
      "description": "Array of validation rules — each returns true or an error message."
    },
    "error": {
      "type": "Boolean",
      "required": false,
      "description": ""
    },
    "errorMessages": {
      "type": "String | Array",
      "default": "[]",
      "required": false,
      "description": "Force one or more error messages."
    },
    "successMessages": {
      "type": "String | Array",
      "default": "[]",
      "required": false,
      "description": "Show success messages (green state)."
    },
    "validateOn": {
      "type": "String",
      "default": "input",
      "required": false,
      "description": "When to validate — input, blur, or submit."
    },
    "disabled": {
      "type": "Boolean",
      "required": false,
      "description": "Disables the field."
    },
    "readonly": {
      "type": "Boolean",
      "required": false,
      "description": "Makes the field read-only."
    },
    "theme": {
      "type": "String",
      "required": false,
      "description": ""
    },
    "class": {
      "type": "String | Array | Object",
      "required": false,
      "description": ""
    },
    "style": {
      "type": "String | Array | Object",
      "default": "null",
      "required": false,
      "description": ""
    }
  },
  "events": {
    "update:modelValue": {
      "description": "Emitted when the value changes."
    },
    "update:focused": {
      "description": "Emitted when focus state changes."
    }
  },
  "slots": {
    "default": {
      "description": "The input element (advanced usage)."
    }
  }
}
