{
  "displayName": "VdCard",
  "props": {
    "type": {
      "type": "String | Number",
      "default": "1",
      "required": false,
      "description": "Layout style 1–5. 1 (default) settles + zooms on hover, 2 reveals a gradient caption, 3 is horizontal, 4 has a frosted caption, 5 pops the caption over the image."
    },
    "image": {
      "type": "String",
      "required": false,
      "description": "Image URL for the card media (shorthand for the `img` slot)."
    },
    "img": {
      "type": "String",
      "required": false,
      "description": "Alias of `image`."
    },
    "title": {
      "type": "String",
      "required": false,
      "description": "Heading text (shorthand for the `title` slot)."
    },
    "text": {
      "type": "String",
      "required": false,
      "description": "Body text (shorthand for the `text` slot)."
    },
    "tag": {
      "type": "String",
      "default": "div",
      "required": false,
      "description": "The root element tag."
    },
    "theme": {
      "type": "String",
      "required": false,
      "description": ""
    },
    "class": {
      "type": "String | Array | Object",
      "required": false,
      "description": ""
    },
    "style": {
      "type": "String | Array | Object",
      "default": "null",
      "required": false,
      "description": ""
    }
  },
  "events": {},
  "slots": {
    "img": {
      "description": "The card image or media."
    },
    "title": {
      "description": "Heading shown above the text."
    },
    "text": {
      "description": "Body copy."
    },
    "interactions": {
      "description": "Buttons overlaid on the image (likes, comments, …)."
    },
    "buttons": {
      "description": "A footer row of actions below the text."
    },
    "default": {
      "description": "Free-form content appended inside the card."
    }
  }
}
