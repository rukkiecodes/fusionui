{
  "displayName": "FNavbar",
  "props": {
    "modelValue": {
      "type": "String",
      "required": false,
      "description": "Active item id (use `v-model`)."
    },
    "fixed": {
      "type": "Boolean",
      "required": false,
      "description": "Pins the bar to the top of the viewport."
    },
    "shadow": {
      "type": "Boolean",
      "required": false,
      "description": "Always shows a soft shadow."
    },
    "shadowScroll": {
      "type": "Boolean",
      "required": false,
      "description": "Shows the shadow only once the page has scrolled."
    },
    "hideScroll": {
      "type": "Boolean",
      "required": false,
      "description": "Slides the bar away when scrolling down, back when scrolling up."
    },
    "paddingScroll": {
      "type": "Boolean",
      "required": false,
      "description": "Extra vertical padding that compresses once the page scrolls."
    },
    "square": {
      "type": "Boolean",
      "required": false,
      "description": "Removes the bottom rounding."
    },
    "notLine": {
      "type": "Boolean",
      "required": false,
      "description": "Hides the sliding active line."
    },
    "color": {
      "type": "String",
      "required": false,
      "description": ""
    },
    "textWhite": {
      "type": "Boolean",
      "required": false,
      "description": ""
    },
    "targetScroll": {
      "type": "String",
      "required": false,
      "description": "CSS selector of the scroll container (defaults to the window)."
    },
    "gooCorner": {
      "type": "Boolean",
      "required": false,
      "description": ""
    },
    "cornerSize": {
      "type": "Number",
      "default": "22",
      "required": false,
      "description": "Radius (px) of the concave fillet where a permanent sidebar meets the navbar."
    },
    "order": {
      "type": "Number",
      "default": "0",
      "required": false,
      "description": "Stacking order inside an <f-layout> — lower sits outer. Default 0 keeps the navbar full-width above the sidebar."
    },
    "island": {
      "type": "Boolean",
      "required": false,
      "description": "Float the bar as an island — a margin on every side plus full rounding."
    },
    "islandMargin": {
      "type": "Number | String",
      "default": "12",
      "required": false,
      "description": "Gap around the bar when island is set (px or any CSS length)."
    },
    "sidebarSelector": {
      "type": "String",
      "default": ".fui-sidebar",
      "required": false,
      "description": ""
    },
    "theme": {
      "type": "String",
      "required": false,
      "description": ""
    },
    "class": {
      "type": "String | Array | Object",
      "required": false,
      "description": ""
    },
    "style": {
      "type": "String | Array | Object",
      "default": "null",
      "required": false,
      "description": ""
    }
  },
  "events": {
    "update:modelValue": {
      "description": "Emitted when an item is activated."
    }
  },
  "slots": {
    "left": {
      "description": "Left section (logo / brand)."
    },
    "default": {
      "description": "Center section — usually `fui-navbar-item`s."
    },
    "right": {
      "description": "Right section (actions)."
    }
  }
}
