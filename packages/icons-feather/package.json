{
  "name": "@vue-dl/icons-feather",
  "version": "0.0.0",
  "description": "Feather icon set for Vue DL — the default icon pack.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "keywords": [
    "vue",
    "vue-dl",
    "icons",
    "feather",
    "svg"
  ],
  "files": [
    "dist",
    "lib",
    "svg"
  ],
  "exports": {
