    "./*": "./src/icons/*.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "node scripts/build-icons.mjs",
    "add-icon": "node scripts/add-icon.mjs",
    "build": "echo \"[icons-feather] build placeholder — bundled in Batch 12\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo \"[icons-feather] no tests yet\""
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vue": "^3.5.13"
  }
}
