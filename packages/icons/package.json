{
  "name": "@fusionui/icons",
  "version": "0.0.0",
  "description": "Feather icon set for FusionUI — the default icon pack.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "keywords": [
    "vue",
    "@fusionui/vue",
    "icons",
    "feather",
    "svg"
  ],
  "files": [
    "dist",
    "svg"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": "./src/icons/*.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/types/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "generate": "node scripts/build-icons.mjs",
    "add-icon": "node scripts/add-icon.mjs",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo \"[icons-feather] no tests yet\""
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vue": "^3.5.13"
  }
}
