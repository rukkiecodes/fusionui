{
  "name": "@rukkiecodes/vue",
  "version": "0.14.0",
  "description": "FusionUI — a Vue 3 design library with the stability of Vuetify and the looks of Vuesax.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vue",
    "vue3",
    "components",
    "ui",
    "design-system",
    "framework",
    "vuesax",
    "vuetify"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles": "./src/styles/main.scss"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/types/index.d.ts",
        "import": "./dist/index.js"
      },
      "./styles": "./dist/fusionui.css"
    }
  },
  "scripts": {
    "build": "vite build && pnpm build:css && pnpm build:types",
    "build:css": "sass src/styles/main.scss dist/fusionui.css --no-source-map --style=compressed",
    "build:types": "tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@rukkiecodes/icons": "workspace:*",
    "@rukkiecodes/tokens": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "sass": "^1.83.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue": "^3.5.13"
  }
}
